# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/jumjuhub?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Kakao OAuth
KAKAO_CLIENT_ID="your-kakao-client-id"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# 공정거래위원회 data.go.kr API
PUBLIC_DATA_API_KEY="your-api-key-here"

# 카카오맵 JavaScript 키 (상권 분석 지도)
NEXT_PUBLIC_KAKAO_MAP_API_KEY="your-kakao-javascript-key"

# Cloudinary (이미지 업로드)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Resend (이메일 알림)
RESEND_API_KEY="re_your-resend-key"
EMAIL_FROM="noreply@jumjuhub.com"

# Google AdSense
NEXT_PUBLIC_ADSENSE_ID="ca-pub-xxxxxxxxxx"

# 봇 포스팅 API 키 (blogAutomation 연동)
BOT_API_KEY="jumjuhub_bot_secret_key_here"

# 구글 인덱싱 API — 서비스 계정 JSON을 base64로 인코딩한 값
GOOGLE_SEARCH_CONSOLE_API_KEY=""

# Vercel Cron 인증 시크릿
CRON_SECRET="랜덤 문자열"
